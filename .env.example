# WORKSPACE_ROOT: 不设置时自动使用 MCP 进程的工作目录（推荐）
# 如需固定路径，取消注释并修改：
# WORKSPACE_ROOT=/path/to/your/project

LLM_BASE_URL=http://127.0.0.1:11434/v1
LLM_API_KEY=ollama
LLM_MODEL=mimo-v2.5

MAX_FILE_CHARS=8000
MAX_OUTPUT_CHARS=6000
MAX_SCAN_FILE_SIZE_BYTES=2097152
MAX_SEARCH_RESULTS=50
MAX_CONTEXT_LINES=200

ENABLE_PROJECT_MAP_CACHE=true
PROJECT_MAP_CACHE_TTL_SEC=300
MAX_PROJECT_MAP_FILES=500
MAX_SUMMARY_FILES=100
MAX_SYMBOL_FILES_FOR_PROJECT_MAP=20
ENABLE_LLM_FILE_SUMMARY=true

MAX_TRACEBACK_CONTEXT_FILES=5
MAX_TRACEBACK_FRAMES=20
ENABLE_DIAGNOSTIC_CACHE=true
DIAGNOSTIC_CACHE_TTL_SEC=300
ENABLE_LLM_DIAGNOSTICS=true

ENABLE_TESTING_CACHE=true
TESTING_CACHE_TTL_SEC=300
ENABLE_LLM_TESTING=true
MAX_REPRO_CONTEXT_FILES=5
MAX_CHANGED_FILES_FOR_VALIDATION=20
MAX_CONFIG_FILES_TO_CHECK=30
MASK_SECRET_VALUES=true

ENABLE_REVIEW_CACHE=true
REVIEW_CACHE_TTL_SEC=300
ENABLE_LLM_REVIEW=true
MAX_DIFF_CHARS=30000
MAX_REVIEW_CHANGED_FILES=20
MAX_IMPACT_SYMBOLS=20
MAX_IMPACT_REFERENCES=100
MAX_DIFF_FILES=50

ENABLE_DISK_CACHE=true
CACHE_DIR=.code_agent_cache
CACHE_VERSION=1

ENABLE_FILE_INDEX_CACHE=true
ENABLE_FILE_SUMMARY_CACHE=true
ENABLE_DIRECTORY_SUMMARY_CACHE=true
ENABLE_PROJECT_PROFILE_CACHE=true
ENABLE_TOOL_RESULT_CACHE=true
ENABLE_PERF_LOG_CACHE=true

FILE_INDEX_CACHE_TTL_SEC=300
FILE_SUMMARY_CACHE_TTL_SEC=86400
DIRECTORY_SUMMARY_CACHE_TTL_SEC=3600
PROJECT_PROFILE_CACHE_TTL_SEC=3600
TOOL_RESULT_CACHE_TTL_SEC=300
PERF_LOG_MAX_ENTRIES=1000

MAX_CACHE_SIZE_MB=200
MAX_CACHE_ENTRY_CHARS=50000
CACHE_MASK_SECRETS=true
CACHE_WRITE_ATOMIC=true
CACHE_SCHEMA_VERSION=1

ENABLE_PROJECT_PROFILE_V2_CACHE=true
PROJECT_PROFILE_V2_CACHE_TTL_SEC=3600
ENABLE_ONBOARDING_PACK_CACHE=true
ONBOARDING_PACK_CACHE_TTL_SEC=600
ENABLE_RUNBOOK_CACHE=true
RUNBOOK_CACHE_TTL_SEC=3600
ENABLE_CONVENTIONS_CACHE=true
CONVENTIONS_CACHE_TTL_SEC=3600

MAX_ONBOARDING_ITEMS=20
MAX_PROFILE_EVIDENCE_ITEMS=50
MAX_RUNBOOK_COMMANDS=20
MAX_CONVENTION_FILES=30

ENABLE_LLM_PROFILE=true
ENABLE_LLM_RUNBOOK=true
ENABLE_LLM_CONVENTIONS=true

ENABLE_PAPER_TOOLS=true
ENABLE_PAPER_CACHE=true
PAPER_CACHE_TTL_SEC=3600

MAX_PAPER_FILES=500
MAX_TEX_FILE_CHARS=50000
MAX_MARKDOWN_FILE_CHARS=50000
MAX_BIB_ENTRIES=2000
MAX_CLAIMS_TO_CHECK=50
MAX_EVIDENCE_ITEMS=100
MAX_CITATION_ITEMS=2000

ENABLE_LLM_PAPER_REVIEW=true
PAPER_LLM_MAX_TOKENS=1200
PAPER_LLM_TEMPERATURE=0.1

PAPER_CACHE_DIR=.code_agent_cache/paper

ENABLE_EXPERIMENT_CACHE=true
EXPERIMENT_CACHE_TTL_SEC=600
ENABLE_LLM_EXPERIMENT_CHECK=true

MAX_TABLES_TO_PARSE=20
MAX_TABLE_FILES=30
MAX_EXPERIMENT_CLAIMS=50
MAX_TABLE_RAW_CHARS=30000
MAX_TABLE_CELL_CHARS=500
MAX_METRIC_OCCURRENCES=200
MAX_EXPERIMENT_OUTPUT_CHARS=12000

ENABLE_WRITING_CACHE=true
WRITING_CACHE_TTL_SEC=600
ENABLE_LLM_WRITING_CHECK=true

MAX_WRITING_INPUT_CHARS=30000
MAX_WRITING_OUTPUT_CHARS=12000
MAX_PARAGRAPH_CHARS=5000
MAX_STYLE_ISSUES=100
MAX_TERMS_TO_CHECK=200
MAX_TERM_OCCURRENCES=200
MAX_ABSTRACT_CHARS=5000
MAX_INTRODUCTION_CHARS=30000
MAX_CONTRIBUTION_CHARS=10000

ENABLE_FIGURE_CACHE=true
FIGURE_CACHE_TTL_SEC=600
ENABLE_LLM_FIGURE_CHECK=true

MAX_FIGURE_ITEMS=200
MAX_CAPTION_ITEMS=100
MAX_CAPTION_CHARS=3000
MAX_CAPTION_CONTEXT_CHARS=5000
MAX_FIGURE_OUTPUT_CHARS=12000
MAX_GRAPHICS_FILES=200
MAX_EQUATIONS_TO_CHECK=100
MAX_LABEL_REFS=500

MCP_TRANSPORT=stdio
MCP_HOST=127.0.0.1
MCP_PORT=8000
MCP_PATH=/mcp
