# ─────────────────────────────────────────────────────────────
# cheap-agent 配置示例
# 复制为 .env 后按需修改。未列出的项均使用代码内置默认值
# （见 cheap_agent/config.py），无需重复设置。
# ─────────────────────────────────────────────────────────────

# ── 必填：LLM（OpenAI 兼容接口） ──────────────────────────────
LLM_BASE_URL=https://token-plan-cn.xiaomimimo.com/v1
LLM_API_KEY=your-key-here
LLM_MODEL=mimo-v2.5-pro

# ── 工作区 ──────────────────────────────────────────────────
# 不设置时自动使用 MCP 进程的工作目录（推荐）
# WORKSPACE_ROOT=/path/to/your/project

# ── 工具集 profile：minimal / code / paper / full / safe / debug
MCP_PROFILE=full

# ── 传输方式 ────────────────────────────────────────────────
# stdio（默认，Codex / Claude Code 本地连接）或 streamable-http
MCP_TRANSPORT=stdio
# MCP_HOST=127.0.0.1
# MCP_PORT=8000
# MCP_PATH=/mcp

# ── 输出大小上限（字符）──────────────────────────────────────
# MAX_FILE_CHARS=8000
# MAX_OUTPUT_CHARS=6000

# ── 磁盘缓存 ────────────────────────────────────────────────
# ENABLE_DISK_CACHE=true
# CACHE_DIR=.code_agent_cache

# ── 安全开关（默认全开 = 严格只读）──────────────────────────
# ENABLE_ONLY_READ_TOOLS=true
# DISABLE_ALL_WRITE_TOOLS=true
# DISABLE_SHELL_TOOLS=true

# ── 关闭某类 LLM 调用（省钱 / 离线时）────────────────────────
# ENABLE_LLM_CODE_TOOLS=true
# ENABLE_LLM_PAPER_TOOLS=true
# ENABLE_LLM_REBUTTAL_TOOLS=true
