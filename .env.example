# WORKSPACE_ROOT: 不设置时自动使用 MCP 进程的工作目录（推荐）
# 如需固定路径，取消注释并修改：
# WORKSPACE_ROOT=/path/to/your/project

LLM_BASE_URL=http://127.0.0.1:11434/v1
LLM_API_KEY=ollama
LLM_MODEL=mimo-v2.5

MAX_FILE_CHARS=8000
MAX_OUTPUT_CHARS=6000
MAX_SCAN_FILE_SIZE_BYTES=2097152
MAX_SEARCH_RESULTS=50
MAX_CONTEXT_LINES=200

ENABLE_PROJECT_MAP_CACHE=true
PROJECT_MAP_CACHE_TTL_SEC=300
MAX_PROJECT_MAP_FILES=500
MAX_SUMMARY_FILES=100
MAX_SYMBOL_FILES_FOR_PROJECT_MAP=20
ENABLE_LLM_FILE_SUMMARY=true

MAX_TRACEBACK_CONTEXT_FILES=5
MAX_TRACEBACK_FRAMES=20
ENABLE_DIAGNOSTIC_CACHE=true
DIAGNOSTIC_CACHE_TTL_SEC=300
ENABLE_LLM_DIAGNOSTICS=true

ENABLE_TESTING_CACHE=true
TESTING_CACHE_TTL_SEC=300
ENABLE_LLM_TESTING=true
MAX_REPRO_CONTEXT_FILES=5
MAX_CHANGED_FILES_FOR_VALIDATION=20
MAX_CONFIG_FILES_TO_CHECK=30
MASK_SECRET_VALUES=true

MCP_TRANSPORT=stdio
MCP_HOST=127.0.0.1
MCP_PORT=8000
MCP_PATH=/mcp
